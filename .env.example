# ── Core (required for Railway deployment) ──────────────────────────────────
GITHUB_TOKEN=your_github_pat_with_repo_scope
GITHUB_REPO=cheeksmagunda/basketball
ANTHROPIC_API_KEY=sk-ant-...
ODDS_API_KEY=your_odds_api_key

# ── Optional Railway secrets ─────────────────────────────────────────────────
INGEST_SECRET=your_ingest_secret        # gates save-most-popular / save-winning-drafts etc.
CRON_SECRET=your_cron_secret            # gates injury-check / auto-improve / force-regenerate
DOCS_SECRET=your_docs_secret            # gates /docs /redoc /openapi.json

# ── Real Sports ingestion automation (local-only, never deployed) ────────────
REAL_SPORTS_USERNAME=your_realsports_username
REAL_SPORTS_PASSWORD=your_realsports_password
REAL_SPORTS_BASE_URL=https://www.realsports.io

# API base for publish.py to POST extracted data to
BASKETBALL_API_BASE=http://localhost:8000   # or https://the-oracle.up.railway.app

# Safety kill-switch — set to false to prevent any browser automation from running
INGEST_AUTOMATION_ENABLED=true
