{
  "ignoreCommand": "git diff --quiet HEAD~1 HEAD -- . ':!data' ':!.github'",
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python", "config": { "maxDuration": 300 } },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/refresh",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/refresh",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/lab/auto-improve",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/refresh-line-odds",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/refresh-line-odds",
      "schedule": "55 * * * *"
    }
  ]
}

